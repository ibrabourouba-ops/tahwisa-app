<!DOCTYPE html>
<html lang="fr">
<head>
  <!-- ============================================================
       TAHWISSA – Site Vitrine & Interactif
       Fichier : index.html
       Description : Structure principale du site. Contient la
       navigation, le hero, les sections patrimoine, hébergements
       et le widget chat IA flottant.
  ============================================================ -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Tahwissa – Voyagez autrement en Algérie. Découvrez des hébergements authentiques chez l'habitant, des expériences uniques et le riche patrimoine culturel algérien." />
  <meta name="keywords" content="Algérie, voyage, hébergement, patrimoine, tourisme, Casbah, Tipaza, Tassili" />
  <meta name="author" content="Tahwissa" />
  <title>TAHWISSA – Voyagez Autrement</title>
  <!-- Polices Google Fonts : Outfit (titres) + Inter (corps) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <!-- Icônes : Feather Icons via CDN -->
  <script src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js"></script>
  <!-- Feuille de styles principale -->
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <!-- ============================================================
       BANDEAU DE NAVIGATION PRINCIPAL
       Contient : Logo, liens nav, sélecteur de langue,
       bouton switch Voyageur/Hôte, connexion et inscription.
  ============================================================ -->
  <header class="navbar" id="navbar">
    <div class="navbar__container">
      <!-- Logo Tahwissa -->
      <a href="#" class="navbar__logo" id="logo-link">
        <span class="logo__tah">TAH</span><span class="logo__wissa">WISSA</span>
        <small class="logo__tagline">Voyagez autrement</small>
      </a>
      <!-- Liens de navigation (visibles en mode Voyageur) -->
      <nav class="navbar__links" id="nav-voyageur-links">
        <a href="hebergement.html" class="nav-link">Hébergements</a>
        <a href="#section-experiences" class="nav-link">Expériences</a>
        <a href="#section-patrimoine" class="nav-link">Patrimoine</a>
        <a href="#" class="nav-link">Blog</a>
      </nav>
      <!-- Liens de navigation (visibles en mode Hôte) -->
      <nav class="navbar__links hidden" id="nav-hote-links">
        <a href="#" class="nav-link">Tableau de bord</a>
        <a href="#" class="nav-link">Mes annonces</a>
        <a href="#" class="nav-link">Réservations</a>
        <a href="#" class="nav-link">Revenus</a>
      </nav>
      <!-- Actions droites de la nav -->
      <div class="navbar__actions">
        <!-- Sélecteur de langue -->
        <button class="btn-lang" id="btn-lang" aria-label="Changer de langue">
          <i data-feather="globe"></i>
          <span>FR/EN</span>
        </button>
        <!-- Bouton Switch Voyageur / Hôte -->
        <button class="btn-switch" id="btn-switch-mode" aria-label="Basculer entre mode Voyageur et Hôte">
          <i data-feather="home" id="switch-icon"></i>
          <span id="switch-label">Passer en Mode Hôte</span>
        </button>
        <!-- Connexion -->
        <button class="btn-ghost" id="btn-connexion">Connexion</button>
        <!-- Inscription -->
        <a href="tahwisa/index.html" class="btn-primary" id="btn-inscription">S'inscrire</a>
      </div>
      <!-- Bouton hamburger mobile -->
      <button class="navbar__hamburger" id="btn-hamburger" aria-label="Menu mobile">
        <span></span><span></span><span></span>
      </button>
    </div>
    <!-- Menu mobile déroulant -->
    <div class="navbar__mobile-menu hidden" id="mobile-menu">
      <a href="hebergement.html" class="mobile-nav-link">Hébergements</a>
      <a href="#section-experiences" class="mobile-nav-link">Expériences</a>
      <a href="#section-patrimoine" class="mobile-nav-link">Patrimoine</a>
      <a href="#" class="mobile-nav-link">Blog</a>
      <div class="mobile-nav-actions">
        <button class="btn-ghost">Connexion</button>
        <a href="tahwisa/index.html" class="btn-primary">S'inscrire</a>
      </div>
    </div>
  </header>
  <!-- ============================================================
       VUE VOYAGEUR (affichée par défaut)
       Contient : Hero, Recherche, Expériences, Patrimoine,
       Hébergements, Témoignages, Footer.
  ============================================================ -->
  <main id="view-voyageur">
<!-- (file truncated in backup) -->
</body>
</html>